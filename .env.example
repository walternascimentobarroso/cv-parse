# MongoDB
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=doctotext
EXTRACTIONS_COLLECTION=extractions

# Upload / documents (MIME types for extractor mapping; must match allowed types)
MIME_TYPE_PDF=application/pdf
MIME_TYPE_PLAIN=text/plain
MAX_DOCUMENT_SIZE_BYTES=10485760
ALLOWED_CONTENT_TYPES=application/pdf,text/plain
